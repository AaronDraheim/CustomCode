param(
    [string]$OutputFolder = 'C:\Temp'
)

# =========================
# MODULES
# =========================
Import-Module Microsoft.Graph.Authentication -ErrorAction Stop
Import-Module Microsoft.Graph.Users -ErrorAction Stop
Import-Module Microsoft.Graph.Identity.SignIns -ErrorAction Stop
Import-Module Microsoft.Graph.Reports -ErrorAction Stop

# Optional Excel export support
$UseExcel = $false
try {
    if (Get-Module -ListAvailable -Name ImportExcel) {
        Import-Module ImportExcel -ErrorAction Stop
        $UseExcel = $true
    }
}
catch {
    $UseExcel = $false
}

# =========================
# CONSTANTS
# =========================
$script:PhoneTypeMap = @{
    '3179e48a-750b-4051-897c-87b9720928f7' = 'mobile'
    'b6332ec1-7057-4abe-9331-3d72feddfe41' = 'alternateMobile'
    'e37fc753-ff3b-4958-9484-eaa9425c82bc' = 'office'
}

# =========================
# FUNCTIONS
# =========================

function Disconnect-GraphSession {
    try {
        if (Get-MgContext) {
            Disconnect-MgGraph | Out-Null
            Write-Host "Disconnected from Microsoft Graph." -ForegroundColor Yellow
        }
        else {
            Write-Host "No active Microsoft Graph session found." -ForegroundColor DarkYellow
        }
    }
    catch {
        Write-Host "Disconnect attempt completed." -ForegroundColor Yellow
    }
}

function Connect-GraphSession {
    Disconnect-GraphSession

    Write-Host "`nConnecting to Microsoft Graph..." -ForegroundColor Cyan

    try {
        Connect-MgGraph -Scopes @(
            'User.Read.All',
            'UserAuthenticationMethod.Read.All',
            'AuditLog.Read.All',
            'Policy.Read.All'
        ) -NoWelcome | Out-Null

        $ctx = Get-MgContext
        if ($ctx) {
            Write-Host "Connected." -ForegroundColor Green
        }
        else {
            Write-Host "Connection did not complete." -ForegroundColor Red
        }
    }
    catch {
        Write-Host "Connection failed: $($_.Exception.Message)" -ForegroundColor Red
    }
}

function Test-GraphConnection {
    $ctx = Get-MgContext
    if (-not $ctx) {
        Write-Host "Not connected to Microsoft Graph. Use option 1 first." -ForegroundColor Red
        return $false
    }
    return $true
}

function Get-SecurityQuestionSignal {
    param(
        $RegistrationRecord,
        [bool]$ModernSecurityQuestionFound
    )

    if ($ModernSecurityQuestionFound) {
        return 'Modern security question object found'
    }
    elseif ($null -ne $RegistrationRecord -and $RegistrationRecord.IsSsprRegistered -eq $true) {
        return 'SSPR registered but no modern object (possible legacy)'
    }
    else {
        return 'No evidence found'
    }
}

function Export-AuditResults {
    param(
        [Parameter(Mandatory = $true)]
        [System.Collections.IEnumerable]$Results,

        [Parameter(Mandatory = $true)]
        [ValidateSet('Top10','Full')]
        [string]$Mode
    )

    if (-not (Test-Path $OutputFolder)) {
        New-Item -Path $OutputFolder -ItemType Directory -Force | Out-Null
    }

    $timestamp = Get-Date -Format 'yyyyMMdd_HHmm'

    if ($UseExcel) {
        $xlsxPath = Join-Path $OutputFolder "AuthAudit_${Mode}_$timestamp.xlsx"

        $Results | Export-Excel `
            -Path $xlsxPath `
            -WorksheetName 'AuditResults' `
            -TableName "AuthAudit$Mode" `
            -TableStyle Medium6 `
            -AutoSize `
            -FreezeTopRow `
            -BoldTopRow

        Write-Host "`nExported Excel: $xlsxPath" -ForegroundColor Green
    }
    else {
        $csvPath = Join-Path $OutputFolder "AuthAudit_${Mode}_$timestamp.csv"

        $Results | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8

        Write-Host "`nImportExcel module not found. Exported CSV instead: $csvPath" -ForegroundColor Yellow
    }

    $txtPath = Join-Path $OutputFolder "AuthAudit_${Mode}_$timestamp.txt"
    $Results | Format-List * | Out-String -Width 4096 | Set-Content -Path $txtPath -Encoding UTF8
    Write-Host "Exported text: $txtPath" -ForegroundColor Green
}

function Get-ModernSecurityQuestionPresence {
    param(
        [Parameter(Mandatory = $true)]
        [string]$UserId
    )

    $modernSQ = $false

    try {
        $methods = Get-MgUserAuthenticationMethod -UserId $UserId -ErrorAction Stop

        foreach ($method in $methods) {
            if ($method.PSObject.Properties.Name -contains 'AdditionalProperties') {
                if ($method.AdditionalProperties.'@odata.type' -eq '#microsoft.graph.securityQuestionAuthenticationMethod') {
                    $modernSQ = $true
                    break
                }
            }

            if ($method.PSObject.Properties.Name -contains '@odata.type') {
                if ($method.'@odata.type' -eq '#microsoft.graph.securityQuestionAuthenticationMethod') {
                    $modernSQ = $true
                    break
                }
            }
        }
    }
    catch {
        $modernSQ = $false
    }

    return $modernSQ
}

function Get-PerUserMfaState {
    param(
        [Parameter(Mandatory = $true)]
        [string]$UserId
    )

    try {
        $req = Invoke-MgGraphRequest `
            -Method GET `
            -Uri "https://graph.microsoft.com/beta/users/$UserId/authentication/requirements" `
            -OutputType PSObject `
            -ErrorAction Stop

        if ($null -ne $req.perUserMfaState) {
            return [string]$req.perUserMfaState
        }

        return 'Unavailable'
    }
    catch {
        return 'Unavailable'
    }
}

function Get-UserPhoneMethods {
    param(
        [Parameter(Mandatory = $true)]
        [string]$UserId
    )

    try {
        return @(Get-MgUserAuthenticationPhoneMethod -UserId $UserId -ErrorAction Stop)
    }
    catch {
        return @()
    }
}

function Run-Audit {
    param(
        [ValidateSet('Top10','Full')]
        [string]$Mode
    )

    if (-not (Test-GraphConnection)) {
        return
    }

    Write-Host "`nStarting $Mode audit..." -ForegroundColor Cyan
    Write-Host "Retrieving registration report..." -ForegroundColor Cyan

    $registrationLookup = @{}
    try {
        $registrationReport = Get-MgReportAuthenticationMethodUserRegistrationDetail -All -ErrorAction Stop
        foreach ($r in $registrationReport) {
            $registrationLookup[$r.Id] = $r
        }
    }
    catch {
        Write-Host "Failed to retrieve registration report: $($_.Exception.Message)" -ForegroundColor Red
        return
    }

    Write-Host "Retrieving users..." -ForegroundColor Cyan
    try {
        $users = @(Get-MgUser -All -Property Id,DisplayName,UserPrincipalName,Mail,AccountEnabled -ErrorAction Stop)
        $users = $users | Where-Object { $_.AccountEnabled -eq $true }
    }
    catch {
        Write-Host "Failed to retrieve users: $($_.Exception.Message)" -ForegroundColor Red
        return
    }

    if ($Mode -eq 'Top10') {
        $users = $users | Select-Object -First 10
    }

    $total = @($users).Count
    if ($total -eq 0) {
        Write-Host "No users found to process." -ForegroundColor Yellow
        return
    }

    $results = [System.Collections.Generic.List[object]]::new()
    $counter = 0

    foreach ($user in $users) {
        $counter++

        # Simple status output instead of Write-Progress
        if ($Mode -eq 'Top10' -or $counter -eq 1 -or $counter % 25 -eq 0 -or $counter -eq $total) {
            Write-Host ("Processing {0} of {1}: {2}" -f $counter, $total, $user.UserPrincipalName) -ForegroundColor DarkCyan
        }

        $reg = $null
        if ($registrationLookup.ContainsKey($user.Id)) {
            $reg = $registrationLookup[$user.Id]
        }

        $mfaState = Get-PerUserMfaState -UserId $user.Id
        $phones   = Get-UserPhoneMethods -UserId $user.Id
        $modernSQ = Get-ModernSecurityQuestionPresence -UserId $user.Id
        $signal   = Get-SecurityQuestionSignal -RegistrationRecord $reg -ModernSecurityQuestionFound $modernSQ

        if (-not $phones -or @($phones).Count -eq 0) {
            $results.Add([PSCustomObject]@{
                UserPrincipalName       = $user.UserPrincipalName
                Email                   = $user.Mail
                PerUserMfaState         = $mfaState
                IsMfaRegistered         = if ($null -ne $reg) { $reg.IsMfaRegistered } else { $null }
                IsSsprRegistered        = if ($null -ne $reg) { $reg.IsSsprRegistered } else { $null }
                SecurityQuestionSignals = $signal
                PhoneType               = 'None'
                PhoneNumber             = ''
            })
        }
        else {
            foreach ($p in $phones) {
                $mapped = if ($script:PhoneTypeMap.ContainsKey([string]$p.Id)) {
                    $script:PhoneTypeMap[[string]$p.Id]
                }
                else {
                    'Unknown'
                }

                $results.Add([PSCustomObject]@{
                    UserPrincipalName       = $user.UserPrincipalName
                    Email                   = $user.Mail
                    PerUserMfaState         = $mfaState
                    IsMfaRegistered         = if ($null -ne $reg) { $reg.IsMfaRegistered } else { $null }
                    IsSsprRegistered        = if ($null -ne $reg) { $reg.IsSsprRegistered } else { $null }
                    SecurityQuestionSignals = $signal
                    PhoneType               = $mapped
                    PhoneNumber             = $p.PhoneNumber
                })
            }
        }
    }

    $sorted = $results | Sort-Object UserPrincipalName, PhoneType

    Write-Host "`nResults:" -ForegroundColor Cyan
    $sorted | Format-Table -AutoSize

    # Always export, including Top10
    Export-AuditResults -Results $sorted -Mode $Mode

    Write-Host "`nAudit complete." -ForegroundColor Green
}

# =========================
# MAIN MENU
# =========================
while ($true) {
    Write-Host "`n===== MAIN MENU =====" -ForegroundColor Cyan
    Write-Host "1. Disconnect / Reconnect Microsoft Graph"
    Write-Host "2. Top 10 Results"
    Write-Host "3. Full Tenant Audit"
    Write-Host "Q. Quit"

    $choice = Read-Host "Select an option"

    switch ($choice.ToUpper()) {
        '1' {
            Connect-GraphSession
        }
        '2' {
            Run-Audit -Mode 'Top10'
        }
        '3' {
            Run-Audit -Mode 'Full'
        }
        'Q' {
            Disconnect-GraphSession
            Write-Host "Exiting..." -ForegroundColor Yellow
            break
        }
        default {
            Write-Host "Invalid selection." -ForegroundColor Red
        }
    }
}
