Import-Module Microsoft.Graph.Identity.SignIns
Import-Module Microsoft.Graph.Users

Connect-MgGraph -Scopes @(
    "UserAuthenticationMethod.Read.All",
    "User.Read.All"
)

# --- Output path ---
$timestamp  = Get-Date -Format 'yyyyMMdd_HHmm'
$reportPath = "C:\AuthMethods_Audit_$timestamp.txt"

# --- Collection ---
$results = [System.Collections.Generic.List[PSCustomObject]]::new()

Write-Host "`n===== AUTH METHODS AUDIT =====" -ForegroundColor Cyan
Write-Host "Retrieving users..." -ForegroundColor Cyan

$users   = Get-MgUser -All -Property Id,DisplayName,UserPrincipalName,Mail,Department,JobTitle
$total   = $users.Count
$counter = 0

foreach ($user in $users) {
    $counter++
    Write-Progress -Activity "Auditing authentication methods" `
                   -Status "$counter of $total — $($user.UserPrincipalName)" `
                   -PercentComplete (($counter / $total) * 100)

    try {
        # --- Phone Methods ---
        $phoneMethods = Get-MgUserAuthenticationPhoneMethod -UserId $user.Id -ErrorAction SilentlyContinue

        # --- Security Questions (SSPR) ---
        # Graph method for security questions
        $securityQuestions = Get-MgUserAuthenticationMethod -UserId $user.Id -ErrorAction SilentlyContinue |
                             Where-Object { $_.'@odata.type' -eq "#microsoft.graph.securityQuestionAuthenticationMethod" }

        $hasSecurityQuestions = if ($securityQuestions) { "Yes" } else { "No" }

        if (-not $phoneMethods) {
            $results.Add([PSCustomObject]@{
                UserPrincipalName = $user.UserPrincipalName
                Email            = $user.Mail
                DisplayName      = $user.DisplayName
                Department       = $user.Department
                JobTitle         = $user.JobTitle
                PhoneType        = "None"
                PhoneNumber      = "N/A"
                SMSCapable       = "No"
                SecurityQuestionsRegistered = $hasSecurityQuestions
            })
        }
        else {
            foreach ($method in $phoneMethods) {
                $phoneType = $method.PhoneType
                $smsCapable = $phoneType -in @("mobile", "alternateMobile")

                $results.Add([PSCustomObject]@{
                    UserPrincipalName = $user.UserPrincipalName
                    Email            = $user.Mail
                    DisplayName      = $user.DisplayName
                    Department       = $user.Department
                    JobTitle         = $user.JobTitle
                    PhoneType        = $phoneType
                    PhoneNumber      = $method.PhoneNumber
                    SMSCapable       = if ($smsCapable) { "Yes" } else { "No" }
                    SecurityQuestionsRegistered = $hasSecurityQuestions
                })
            }
        }
    }
    catch {
        $results.Add([PSCustomObject]@{
            UserPrincipalName = $user.UserPrincipalName
            Email            = $user.Mail
            DisplayName      = $user.DisplayName
            Department       = $user.Department
            JobTitle         = $user.JobTitle
            PhoneType        = "ERROR"
            PhoneNumber      = "N/A"
            SMSCapable       = "N/A"
            SecurityQuestionsRegistered = "Unknown"
        })
    }
}

Write-Progress -Activity "Auditing authentication methods" -Completed

# --- Sort results ---
$sortedResults = $results | Sort-Object UserPrincipalName

# --- Top 10 ---
Write-Host "`nTop 10 Results:" -ForegroundColor Cyan
$sortedResults | Select-Object -First 10 | Format-Table `
    UserPrincipalName, Email, PhoneType, PhoneNumber, SMSCapable, SecurityQuestionsRegistered -AutoSize

# --- Export FULL list (Format-List) ---
$sortedResults | Format-List * | Out-String | Set-Content $reportPath

Write-Host "`nFull report exported: $reportPath" -ForegroundColor Green

Disconnect-MgGraph
