# Helper: reads a true/false property from a registration-report row, whether Graph returns the name as 'isMfaCapable' (REST/JSON) or 'IsMfaCapable' (PowerShell SDK).
function Get-RegistrationBool {param($RegistrationRecord,[string]$Lower,[string]$Pascal)if ($null -eq $RegistrationRecord) { return $false }if ($RegistrationRecord.PSObject.Properties.Name -contains $Lower -and $null -ne $RegistrationRecord.$Lower) { return [bool]$RegistrationRecord.$Lower }if ($RegistrationRecord.PSObject.Properties.Name -contains $Pascal -and $null -ne $RegistrationRecord.$Pascal) { return [bool]$RegistrationRecord.$Pascal }return $false}
# Helper: return the methodsRegistered array from a registration-report row.
function Get-RegistrationMethods {param($RegistrationRecord)if ($null -eq $RegistrationRecord) { return @() }if ($RegistrationRecord.PSObject.Properties.Name -contains 'methodsRegistered' -and $null -ne $RegistrationRecord.methodsRegistered) { return @($RegistrationRecord.methodsRegistered) }if ($RegistrationRecord.PSObject.Properties.Name -contains 'MethodsRegistered' -and $null -ne $RegistrationRecord.MethodsRegistered) { return @($RegistrationRecord.MethodsRegistered) }return @()}
# Helper: return true if any value matches any of the supplied regex patterns.
function Test-StringPatternMatch {param([Parameter()][object[]]$Values = @(),[Parameter()][string[]]$Patterns = @())foreach ($value in @($Values)) {$text = [string]$value;foreach ($pattern in @($Patterns)) {if ($text -match $pattern) { return $true }}}return $false}
# Determine whether the user has security questions registered.
function Get-SecurityQuestionStatus {param($RegistrationRecord,[bool]$ModernSecurityQuestionFound)$registered = $ModernSecurityQuestionFound;if (-not $registered -and $null -ne $RegistrationRecord) {$methods = Get-RegistrationMethods -RegistrationRecord $RegistrationRecord;foreach ($m in @($methods)) {if ([string]$m -match 'security' -or [string]$m -match 'question') {$registered = $true;break}}}return [PSCustomObject]@{SecurityQuestionsRegistered = $registered}}
# Prompt for and validate the number of users to sample.
function Get-SampleSize {
    while ($true) {
        $inputValue = Read-Host "Enter number of users to sample"

        if ([string]::IsNullOrWhiteSpace($inputValue)) {
            Write-Host "A value is required." -ForegroundColor Red
            continue
        }

        $parsedValue = 0
        if ([int]::TryParse($inputValue, [ref]$parsedValue) -and $parsedValue -gt 0) {
            return $parsedValue
        }

        Write-Host "Enter a whole number greater than 0." -ForegroundColor Red
    }
}
# Prompt for an optional UPN-suffix domain filter (comma-separated; * = all domains).
function Get-DomainFilter {
    while ($true) {
        Write-Host ""
        Write-Host "Optional domain filter" -ForegroundColor Cyan
        Write-Host "Examples:"
        Write-Host "  contoso.com"
        Write-Host "  contoso.com,fabrikam.com"
        Write-Host "  *   (all domains / no filter)"
        $inputValue = Read-Host "Enter UPN domain filter"

        if ([string]::IsNullOrWhiteSpace($inputValue) -or $inputValue -eq '*') {
            return @()
        }

        $domains = $inputValue.Split(',') |
            ForEach-Object { $_.Trim().ToLowerInvariant() } |
            Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
            Sort-Object -Unique

        if (@($domains).Count -gt 0) {
            return @($domains)
        }

        Write-Host "Enter one or more valid domains, or * for all." -ForegroundColor Red
    }
}
# Prompt for one or more specific UPNs to target.
function Get-UpnFilter {
    while ($true) {
        Write-Host ""
        Write-Host "Specific UPN filter" -ForegroundColor Cyan
        Write-Host "Examples:"
        Write-Host "  user1@contoso.com"
        Write-Host "  user1@contoso.com,user2@contoso.com"
        Write-Host "  *   (cancel / none)"
        $inputValue = Read-Host "Enter one or more specific UPNs"

        if ([string]::IsNullOrWhiteSpace($inputValue) -or $inputValue -eq '*') {
            return @()
        }

        $upns = $inputValue.Split(',') |
            ForEach-Object { $_.Trim().ToLowerInvariant() } |
            Where-Object { -not [string]::IsNullOrWhiteSpace($_) } |
            Sort-Object -Unique

        if (@($upns).Count -gt 0) {
            return @($upns)
        }

        Write-Host "Enter one or more valid UPNs, or * to cancel." -ForegroundColor Red
    }
}
# Summarize a user's phone methods into types, numbers, and access mode.
function Get-UserPhoneSummary {param([Parameter()][object[]]$PhoneMethods = @())$phoneTypes = [System.Collections.Generic.List[string]]::new();$phoneNumbers = [System.Collections.Generic.List[string]]::new();$hasMobile = $false;$hasAlternateMobile = $false;$hasOffice = $false;foreach ($phone in @($PhoneMethods)) {$phoneType = $null;if ($phone.PSObject.Properties.Name -contains 'PhoneType' -and $null -ne $phone.PhoneType) {$phoneType = [string]$phone.PhoneType}elseif ($phone.PSObject.Properties.Name -contains 'AdditionalProperties' -and $null -ne $phone.AdditionalProperties -and $phone.AdditionalProperties.ContainsKey('phoneType')) {$phoneType = [string]$phone.AdditionalProperties['phoneType']}elseif ($script:PhoneTypeMap.ContainsKey([string]$phone.Id)) {$phoneType = $script:PhoneTypeMap[[string]$phone.Id]}if ([string]::IsNullOrWhiteSpace($phoneType)) {$phoneType = 'Unknown'}$phoneTypes.Add($phoneType);switch ($phoneType) {'mobile' {$hasMobile = $true}'alternateMobile' {$hasAlternateMobile = $true}'office' {$hasOffice = $true}}if ($phone.PSObject.Properties.Name -contains 'PhoneNumber' -and -not [string]::IsNullOrWhiteSpace([string]$phone.PhoneNumber)) {$phoneNumbers.Add([string]$phone.PhoneNumber)}}$phoneAccessMode = if ($hasMobile) { 'SMS and voice call (mobile)' } elseif ($hasAlternateMobile -or $hasOffice) { 'Voice call only' } else { 'None' };return [PSCustomObject]@{PhoneTypes = $(if ($phoneTypes.Count -gt 0) { ($phoneTypes | Sort-Object -Unique) -join '; ' } else { 'None' });PhoneNumbers = $(if ($phoneNumbers.Count -gt 0) { ($phoneNumbers | Sort-Object -Unique) -join '; ' } else { '' });PhoneAccessMode = $phoneAccessMode}}
# Evaluate whether SMS/voice MFA is likely available for the user.
function Get-SmsMfaCapability {
    param(
        $RegistrationRecord,
        [bool]$MobilePhoneRegisteredLive
    )


    $isMfaCapable    = Get-RegistrationBool -RegistrationRecord $RegistrationRecord -Lower 'isMfaCapable' -Pascal 'IsMfaCapable'
    $isMfaRegistered = Get-RegistrationBool -RegistrationRecord $RegistrationRecord -Lower 'isMfaRegistered' -Pascal 'IsMfaRegistered'

    $registeredMethods = Get-RegistrationMethods -RegistrationRecord $RegistrationRecord

    # Mobile-only matching. Office numbers are voice-only and are intentionally excluded.
    $mobileFromReport = Test-StringPatternMatch `
        -Values $registeredMethods `
        -Patterns @('mobilePhone', '^sms$')

    $mobilePhoneRegistered = ($MobilePhoneRegisteredLive -or $mobileFromReport)

    $smsMfaLikely = ($mobilePhoneRegistered -eq $true)

    return [PSCustomObject]@{
        IsMfaCapable          = $isMfaCapable
        IsMfaRegistered       = $isMfaRegistered
        MobilePhoneRegistered = $mobilePhoneRegistered
        SmsMfaLikelyAvailable = $smsMfaLikely
    }
}

