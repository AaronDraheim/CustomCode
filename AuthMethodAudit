# Resolve a specific list of UPNs into user objects.
function Get-TargetedUsers {
    param([Parameter(Mandatory = $true)][string[]]$UpnFilter)
    $users = [System.Collections.Generic.List[object]]::new()
    foreach ($upn in @($UpnFilter)) {
        try {
            $u = Get-MgUser -UserId $upn -Property Id,DisplayName,UserPrincipalName,Mail,AccountEnabled -ErrorAction Stop
            if ($null -ne $u) {
                $users.Add($u)
            }
        }
        catch {
            Write-Host "Unable to find user $upn : $($_.Exception.Message)" -ForegroundColor Yellow
        }
    }
    return @($users)
}
# Build a hashtable of registration-report details keyed by user Id (targeted or full report).
function Get-RegistrationLookup {
    param(
        [string]$Mode,
        [object[]]$Users,
        [string[]]$UpnFilter
    )

    $registrationLookup = @{}

    if ($Mode -eq 'Targeted' -and @($UpnFilter).Count -gt 0 -and @($Users).Count -gt 0) {
        foreach ($u in @($Users)) {
            try {
                $uri = "https://graph.microsoft.com/beta/reports/authenticationMethods/userRegistrationDetails/$($u.Id)"
                $detail = Invoke-MgGraphRequest -Method GET -Uri $uri -OutputType PSObject -ErrorAction Stop
                if ($null -ne $detail) {
                    $registrationLookup[$u.Id] = $detail
                }
            }
            catch {
                # continue if targeted user has no report row
            }
        }
    }
    else {
        $registrationReport = Get-MgReportAuthenticationMethodUserRegistrationDetail -All -ErrorAction Stop
        foreach ($r in $registrationReport) {
            $registrationLookup[$r.Id] = $r
        }
    }

    return $registrationLookup
}
# Export the audit results to Excel (or CSV) plus a text summary, with a scoped file name.
function Export-AuditResults {
    param(
        [Parameter(Mandatory = $true)][object[]]$Results,
        [Parameter(Mandatory = $true)][string]$ModeLabel,
        [Parameter(Mandatory = $true)][ValidateSet('Enabled','All')][string]$AccountScope,
        [string[]]$DomainFilter = @(),
        [string[]]$UpnFilter = @()
    )
    if (@($Results).Count -eq 0) { Write-Host "No results to export." -ForegroundColor Yellow; return }

    if (-not (Test-Path $OutputFolder)) {
        New-Item -Path $OutputFolder -ItemType Directory -Force | Out-Null
    }

    $timestamp = Get-Date -Format 'yyyyMMdd_HHmm'
    $safeModeLabel = $ModeLabel -replace '[^A-Za-z0-9]', ''
    $scopeLabel = if (@($UpnFilter).Count -gt 0) {
        'SpecificUPNs'
    }
    elseif (@($DomainFilter).Count -gt 0) {
        (($DomainFilter -join '_') -replace '[^A-Za-z0-9_\-]', '')
    }
    else {
        'AllDomains'
    }

    $baseName = "AuthAudit_${AccountScope}_${safeModeLabel}_${scopeLabel}_$timestamp"

    if ($UseExcel) {
        $xlsxPath = Join-Path $OutputFolder "$baseName.xlsx"
        $Results | Export-Excel `
            -Path $xlsxPath `
            -WorksheetName 'AuditResults' `
            -TableName ("AuthAudit{0}{1}" -f $AccountScope, $safeModeLabel) `
            -TableStyle Medium6 `
            -AutoSize `
            -FreezeTopRow `
            -BoldTopRow
        Write-Host "`nExported Excel: $xlsxPath" -ForegroundColor Green
    }
    else {
        $csvPath = Join-Path $OutputFolder "$baseName.csv"
        $Results | Export-Csv -Path $csvPath -NoTypeInformation -Encoding UTF8

        Write-Host "`nImportExcel module not found. Exported CSV: $csvPath" -ForegroundColor Yellow

    }
    $txtPath = Join-Path $OutputFolder "$baseName.txt"
    $Results | Format-List * | Out-String -Width 4096 | Set-Content -Path $txtPath -Encoding UTF8
    Write-Host "Exported text: $txtPath" -ForegroundColor Green
}
# Core audit engine: retrieve users, apply scope/domain/UPN filters, collect auth data, export results.
function Run-Audit {
    param(
        [string]$Mode = 'Full',
        [Parameter(Mandatory = $true)][ValidateSet('Enabled','All')][string]$AccountScope,
        [int]$SampleSize = 0,
        [string[]]$DomainFilter = @(),
        [string[]]$UpnFilter = @()
    )

    if (-not (Test-GraphConnection)) {
        return
    }

    $modeLabel = switch ($Mode) {
        'Sample'   { "Sample$SampleSize" }
        'Targeted' { 'TargetedUPN' }
        default    { 'Full' }
    }

    Write-Host "`nStarting $modeLabel audit for $AccountScope accounts..." -ForegroundColor Cyan

    if (@($UpnFilter).Count -gt 0) {
        Write-Host "UPN filter: $($UpnFilter -join ', ')" -ForegroundColor DarkCyan
    }
    elseif (@($DomainFilter).Count -gt 0) {
        Write-Host "Domain filter: $($DomainFilter -join ', ')" -ForegroundColor DarkCyan
    }
    else {
        Write-Host "Domain filter: All domains" -ForegroundColor DarkCyan
    }

    $tenantSms = Get-TenantSmsPolicyState
    Write-Host "Tenant SMS method policy state: $($tenantSms.SmsPolicyState)" -ForegroundColor DarkCyan

    Write-Progress -Activity "Preparing Audit" -Status "Retrieving users..." -PercentComplete 10

    try {
        if ($Mode -eq 'Targeted' -and @($UpnFilter).Count -gt 0) {
            $users = @(Get-TargetedUsers -UpnFilter $UpnFilter)
            if ($AccountScope -eq 'Enabled') {
                $users = @($users | Where-Object { $_.AccountEnabled -eq $true })
            }
        }
        else {
            $users = @(Get-MgUser -All -Property Id,DisplayName,UserPrincipalName,Mail,AccountEnabled -ErrorAction Stop)

            if ($AccountScope -eq 'Enabled') {
                $users = @($users | Where-Object { $_.AccountEnabled -eq $true })
            }

            if (@($DomainFilter).Count -gt 0) {
                $users = @($users | Where-Object {
                    $upnDomain = $null
                    if (-not [string]::IsNullOrWhiteSpace($_.UserPrincipalName) -and $_.UserPrincipalName -match '@') {
                        $upnDomain = ($_.UserPrincipalName.Split('@')[-1]).ToLowerInvariant()
                    }
                    $upnDomain -in $DomainFilter
                })
            }

            if (@($UpnFilter).Count -gt 0) {
                $users = @($users | Where-Object {
                    -not [string]::IsNullOrWhiteSpace($_.UserPrincipalName) -and
                    $_.UserPrincipalName.ToLowerInvariant() -in $UpnFilter
                })
            }
        }
    }
    catch {
        Write-Host "Failed to retrieve users: $($_.Exception.Message)" -ForegroundColor Red
        Write-Progress -Activity "Preparing Audit" -Completed
        return
    }

    if ($Mode -eq 'Sample') {
        $users = @($users | Select-Object -First $SampleSize)
    }

    $total = @($users).Count
    if ($total -eq 0) {
        Write-Host "No users found to process." -ForegroundColor Yellow
        Write-Progress -Activity "Preparing Audit" -Completed
        return
    }

    Write-Progress -Activity "Preparing Audit" -Status "Retrieving authentication registration report..." -PercentComplete 25

    try {
        $registrationLookup = Get-RegistrationLookup -Mode $Mode -Users $users -UpnFilter $UpnFilter
    }
    catch {
        Write-Host "Failed to retrieve registration report: $($_.Exception.Message)" -ForegroundColor Red
        Write-Progress -Activity "Preparing Audit" -Completed
        return
    }

    $results = [System.Collections.Generic.List[object]]::new()
    $counter = 0

    foreach ($user in $users) {
        $counter++
        $percent = [math]::Round(25 + (($counter / $total) * 75), 0)

        Write-Progress `
            -Activity "Auditing Users ($AccountScope / $modeLabel)" `
            -Status "$counter of $total processed" `
            -PercentComplete $percent

        $reg = $null
        if ($registrationLookup.ContainsKey($user.Id)) {
            $reg = $registrationLookup[$user.Id]
        }

        try {
            $perUserMfa = Get-PerUserMfaState -UserId $user.Id
            $phones     = Get-UserPhoneMethods -UserId $user.Id
            $phoneSummary = Get-UserPhoneSummary -PhoneMethods @($phones)
            $authInv    = Get-UserAuthMethodInventory -UserId $user.Id -PhoneMethods @($phones)
            $sqStatus   = Get-SecurityQuestionStatus -RegistrationRecord $reg -ModernSecurityQuestionFound $authInv.ModernSecurityQuestion
            $smsCap     = Get-SmsMfaCapability -RegistrationRecord $reg -MobilePhoneRegisteredLive $authInv.MobilePhoneRegistered
            $signInView = Get-UserSignInMethodView -UserId $user.Id
        }
        catch {
            Write-Host "Failed processing $($user.UserPrincipalName): $($_.Exception.Message)" -ForegroundColor Red
            continue
        }

$results.Add([PSCustomObject]@{UserPrincipalName = $user.UserPrincipalName;Email = $user.Mail;AccountEnabled = $user.AccountEnabled;Domain = $(if ($user.UserPrincipalName -match '@') { $user.UserPrincipalName.Split('@')[-1] } else { '' });PerUserMfaState = $perUserMfa;SignInMode = $signInView.SignInMode;UserDefaultSignInMethod = $signInView.UserDefaultSignInMethod;SystemPreferredEnabled = $signInView.SystemPreferredEnabled;IsMfaRegistered = $smsCap.IsMfaRegistered;IsMfaCapable = $smsCap.IsMfaCapable;TenantSmsPolicyState = $tenantSms.SmsPolicyState;MobilePhoneRegistered = $smsCap.MobilePhoneRegistered;SmsMfaLikelyAvailable = $smsCap.SmsMfaLikelyAvailable;SecurityQuestionsRegistered = $sqStatus.SecurityQuestionsRegistered;AllRegisteredAuthMethods = $authInv.AllRegisteredAuthMethods;CountableRegisteredAuthMethodCount = $authInv.CountableRegisteredAuthMethodCount;'Migration Ready' = $authInv.HasTwoOrMoreCountableAuthMethods;PhoneTypes = $phoneSummary.PhoneTypes;PhoneAccessMode = $phoneSummary.PhoneAccessMode})
    }

    Write-Progress -Activity "Auditing Users" -Completed

$sorted = @($results | Sort-Object UserPrincipalName)

    Export-AuditResults `
        -Results @($sorted) `
        -ModeLabel $modeLabel `
        -AccountScope $AccountScope `
        -DomainFilter $DomainFilter `
        -UpnFilter $UpnFilter

    Write-Host "`nAudit complete. Results exported." -ForegroundColor Green
}

# Sub-menu to choose Sample / Full Tenant / Specific UPN audits for the selected account scope.
function Show-AuditSubMenu {
    param([Parameter(Mandatory = $true)][ValidateSet('Enabled','All')][string]$AccountScope)

    while ($true) {
        Write-Host ""
        Write-Host "===== $AccountScope ACCOUNTS MENU =====" -ForegroundColor Cyan
        Write-Host "1. Sample Results (prompt for count)"
        Write-Host "2. Full Tenant Audit"
        Write-Host "3. Specific UPN(s)"
        Write-Host "B. Back"

        $subChoice = Read-Host "Select an option"

        switch ($subChoice.ToUpper()) {
            '1' {
                $sampleSize = Get-SampleSize
                $domainFilter = Get-DomainFilter
                Run-Audit -Mode 'Sample' -AccountScope $AccountScope -SampleSize $sampleSize -DomainFilter $domainFilter
            }
            '2' {
                $domainFilter = Get-DomainFilter
                Run-Audit -Mode 'Full' -AccountScope $AccountScope -DomainFilter $domainFilter
            }
            '3' {
                $upnFilter = Get-UpnFilter
                if (@($upnFilter).Count -gt 0) {
                    Run-Audit -Mode 'Targeted' -AccountScope $AccountScope -UpnFilter $upnFilter
                }
                else {
                    Write-Host "No UPNs entered." -ForegroundColor Yellow
                }
            }
            'B' {
                return
            }
            default {
                Write-Host "Invalid selection." -ForegroundColor Red
            }
        }
    }
}

# =========================
# MAIN MENU
# =========================
# =========================
:mainLoop while ($true) {
    Write-Host "`n===== MAIN MENU =====" -ForegroundColor Cyan
    Write-Host "1. Disconnect / Reconnect Microsoft Graph"
    Write-Host "2. Audit Enabled Accounts"
    Write-Host "3. Audit All Accounts"
    Write-Host "Q. Quit"

    $choice = Read-Host "Select an option"

    switch ($choice.ToUpper()) {
        '1' { Connect-GraphSession }
        '2' { Show-AuditSubMenu -AccountScope 'Enabled' }
        '3' { Show-AuditSubMenu -AccountScope 'All' }
        'Q' {
            Disconnect-GraphSession
            Write-Host "Exiting..." -ForegroundColor Yellow
            break mainLoop
        }
        default {
            Write-Host "Invalid selection." -ForegroundColor Red
        }
    }
}

