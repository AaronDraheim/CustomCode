# Safely tear down any existing Microsoft Graph session.
function Disconnect-GraphSession {
    try {
        if (Get-MgContext) {
            Disconnect-MgGraph | Out-Null
            Write-Host "Disconnected from Microsoft Graph." -ForegroundColor Yellow
        }
        else {
            Write-Host "No active Microsoft Graph session found." -ForegroundColor DarkYellow
        }
    }
    catch {
        Write-Host "Disconnect attempt completed." -ForegroundColor Yellow
    }
}

# Connect to Microsoft Graph with the scopes required for the audit.
function Connect-GraphSession {
    Disconnect-GraphSession
    Write-Host "`nConnecting to Microsoft Graph..." -ForegroundColor Cyan
    try {
        Connect-MgGraph -Scopes @(
            'User.Read.All',
            'UserAuthenticationMethod.Read.All',
            'AuditLog.Read.All',
            'Policy.Read.All'
        ) -NoWelcome | Out-Null

        if (Get-MgContext) {
            Write-Host "Connected." -ForegroundColor Green
        }
        else {
            Write-Host "Connection did not complete." -ForegroundColor Red
        }
    }
    catch {
        Write-Host "Connection failed: $($_.Exception.Message)" -ForegroundColor Red
    }
}

# Verify an active Graph session exists before running an audit.
function Test-GraphConnection {
    if (-not (Get-MgContext)) {
        Write-Host "Not connected to Microsoft Graph. Use option 1 first." -ForegroundColor Red
        return $false
    }
    return $true
}

