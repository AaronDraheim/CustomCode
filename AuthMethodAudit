# Query the tenant SMS authentication-method policy state (run once per audit).
function Get-TenantSmsPolicyState {
    $result = [PSCustomObject]@{
        SmsPolicyEnabled = $false
        SmsPolicyState   = 'Unknown'
    }

    try {
        $policy = Invoke-MgGraphRequest `
            -Method GET `
            -Uri "https://graph.microsoft.com/beta/policies/authenticationMethodsPolicy/authenticationMethodConfigurations/Sms" `
            -OutputType PSObject `
            -ErrorAction Stop

        $state = $null
        if ($policy.PSObject.Properties.Name -contains 'state') {
            $state = [string]$policy.state
        }
        elseif ($policy.PSObject.Properties.Name -contains 'AdditionalProperties' -and
                $null -ne $policy.AdditionalProperties -and
                $policy.AdditionalProperties.ContainsKey('state')) {
            $state = [string]$policy.AdditionalProperties['state']
        }

        if (-not [string]::IsNullOrWhiteSpace($state)) {
            $result.SmsPolicyState   = $state
            $result.SmsPolicyEnabled = ($state -eq 'enabled')
        }
    }
    catch {
        $result.SmsPolicyState = 'Unavailable'
    }

    return $result
}

