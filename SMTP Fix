[CmdletBinding()]
param (
    [Parameter()]
    [string]$InputPath,

    [Parameter()]
    [string]$TranscriptPath,

    [Parameter()]
    [string]$ErrorListPath
)

$script:InputPath = $InputPath
$script:TranscriptPath = $TranscriptPath
$script:ErrorListPath = $ErrorListPath
$script:Errors = New-Object System.Collections.Generic.List[object]
$script:TranscriptStarted = $false

function Select-FilePath {
    param (
        [Parameter(Mandatory)]
        [string]$Title,

        [string]$Filter = "CSV files (*.csv)|*.csv|All files (*.*)|*.*"
    )

    do {
        Clear-Host
        Write-Host $Title -ForegroundColor Cyan
        Write-Host ("=" * $Title.Length) -ForegroundColor Cyan
        Write-Host ""
        Write-Host "1. Browse for file using UI picker"
        Write-Host "2. Manually enter file path"
        Write-Host "R. Return"
        Write-Host ""

        $selection = Read-Host "Select an option"

        switch ($selection.ToUpper()) {
            "1" {
                try {
                    Add-Type -AssemblyName System.Windows.Forms -ErrorAction Stop

                    $openFileDialog = New-Object System.Windows.Forms.OpenFileDialog
                    $openFileDialog.Title = $Title
                    $openFileDialog.Filter = $Filter
                    $openFileDialog.Multiselect = $false

                    $result = $openFileDialog.ShowDialog()

                    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
                        return $openFileDialog.FileName
                    }
                    else {
                        Write-Host "No file was selected." -ForegroundColor Yellow
                        Read-Host "Press Enter to continue"
                    }
                }
                catch {
                    Write-Host "UI file picker could not be opened. Error: $($_.Exception.Message)" -ForegroundColor Red
                    Write-Host "Use manual file path entry instead." -ForegroundColor Yellow
                    Read-Host "Press Enter to continue"
                }
            }

            "2" {
                $manualPath = Read-Host "Enter the full file path"

                if ([string]::IsNullOrWhiteSpace($manualPath)) {
                    Write-Host "No file path was entered." -ForegroundColor Red
                    Read-Host "Press Enter to continue"
                }
                else {
                    return $manualPath
                }
            }

            "R" {
                return $null
            }

            default {
                Write-Host "Invalid selection. Select 1, 2, or R." -ForegroundColor Red
                Read-Host "Press Enter to continue"
            }
        }
    }
    while ($true)
}

function Select-SaveFilePath {
    param (
        [Parameter(Mandatory)]
        [string]$Title,

        [string]$Filter = "CSV files (*.csv)|*.csv|All files (*.*)|*.*",

        [string]$DefaultFileName = "Output.csv"
    )

    do {
        Clear-Host
        Write-Host $Title -ForegroundColor Cyan
        Write-Host ("=" * $Title.Length) -ForegroundColor Cyan
        Write-Host ""
        Write-Host "1. Browse for save location using UI picker"
        Write-Host "2. Manually enter output file path"
        Write-Host "R. Return"
        Write-Host ""

        $selection = Read-Host "Select an option"

        switch ($selection.ToUpper()) {
            "1" {
                try {
                    Add-Type -AssemblyName System.Windows.Forms -ErrorAction Stop

                    $saveFileDialog = New-Object System.Windows.Forms.SaveFileDialog
                    $saveFileDialog.Title = $Title
                    $saveFileDialog.Filter = $Filter
                    $saveFileDialog.FileName = $DefaultFileName
                    $saveFileDialog.OverwritePrompt = $true

                    $result = $saveFileDialog.ShowDialog()

                    if ($result -eq [System.Windows.Forms.DialogResult]::OK) {
                        return $saveFileDialog.FileName
                    }
                    else {
                        Write-Host "No output path was selected." -ForegroundColor Yellow
                        Read-Host "Press Enter to continue"
                    }
                }
                catch {
                    Write-Host "UI save picker could not be opened. Error: $($_.Exception.Message)" -ForegroundColor Red
                    Write-Host "Use manual output path entry instead." -ForegroundColor Yellow
                    Read-Host "Press Enter to continue"
                }
            }

            "2" {
                $manualPath = Read-Host "Enter the full output file path"

                if ([string]::IsNullOrWhiteSpace($manualPath)) {
                    Write-Host "No output path was entered." -ForegroundColor Red
                    Read-Host "Press Enter to continue"
                }
                else {
                    return $manualPath
                }
            }

            "R" {
                return $null
            }

            default {
                Write-Host "Invalid selection. Select 1, 2, or R." -ForegroundColor Red
                Read-Host "Press Enter to continue"
            }
        }
    }
    while ($true)
}

function Start-LogIfConfigured {
    if (-not [string]::IsNullOrWhiteSpace($script:TranscriptPath) -and -not $script:TranscriptStarted) {
        $TranscriptDirectory = Split-Path -Path $script:TranscriptPath -Parent

        if (-not [string]::IsNullOrWhiteSpace($TranscriptDirectory) -and -not (Test-Path -Path $TranscriptDirectory)) {
            New-Item -Path $TranscriptDirectory -ItemType Directory -Force | Out-Null
        }

        Start-Transcript -Path $script:TranscriptPath -Append
        $script:TranscriptStarted = $true
    }
}

function Add-ErrorRecord {
    param (
        [string]$RecipientType,
        [string]$Identity,
        [string]$Reason,
        [string]$Details
    )

    $script:Errors.Add([pscustomobject]@{
        Timestamp     = Get-Date
        RecipientType = $RecipientType
        Identity      = $Identity
        Reason        = $Reason
        Details       = $Details
    })
}

function Export-ErrorList {
    if ([string]::IsNullOrWhiteSpace($script:ErrorListPath)) {
        $script:ErrorListPath = Select-SaveFilePath `
            -Title "Select error list output path" `
            -Filter "CSV files (*.csv)|*.csv|All files (*.*)|*.*" `
            -DefaultFileName "MailRecipientErrors.csv"
    }

    if ([string]::IsNullOrWhiteSpace($script:ErrorListPath)) {
        Write-Host "No error list path was selected." -ForegroundColor Red
        return
    }

    $ErrorDirectory = Split-Path -Path $script:ErrorListPath -Parent

    if (-not [string]::IsNullOrWhiteSpace($ErrorDirectory) -and -not (Test-Path -Path $ErrorDirectory)) {
        New-Item -Path $ErrorDirectory -ItemType Directory -Force | Out-Null
    }

    if ($script:Errors.Count -gt 0) {
        $script:Errors | Export-Csv -Path $script:ErrorListPath -NoTypeInformation -Encoding UTF8
        Write-Host "Error list exported to: $script:ErrorListPath" -ForegroundColor Green
    }
    else {
        @(
            [pscustomobject]@{
                Timestamp     = Get-Date
                RecipientType = "N/A"
                Identity      = "N/A"
                Reason        = "No errors recorded"
                Details       = "No failures or warnings were captured during this run."
            }
        ) | Export-Csv -Path $script:ErrorListPath -NoTypeInformation -Encoding UTF8

        Write-Host "No errors were recorded. Empty error report exported to: $script:ErrorListPath" -ForegroundColor Green
    }
}

function Get-PrimarySmtpFromAddresses {
    param (
        [string[]]$ProxyAddresses
    )

    $allAddresses = $ProxyAddresses | ForEach-Object {
        $_.ToString().Trim()
    } | Where-Object {
        -not [string]::IsNullOrWhiteSpace($_)
    }

    $primary = $allAddresses | Where-Object {
        $_ -cmatch '^SMTP:'
    } | Select-Object -First 1

    return $primary
}

function Invoke-MailUserCleanup {
    param (
        [Parameter(Mandatory)]
        [string]$Identity,

        [string[]]$ProxyAddresses
    )

    try {
        Write-Host "Processing mail user: $Identity" -ForegroundColor Yellow

        if (-not $ProxyAddresses -or $ProxyAddresses.Count -eq 0) {
            Write-Host "No proxy addresses provided from CSV. Reading mail user from Exchange Online..." -ForegroundColor Cyan

            $mailUser = Get-MailUser -Identity $Identity -ErrorAction Stop
            $ProxyAddresses = $mailUser.EmailAddresses
        }

        $primary = Get-PrimarySmtpFromAddresses -ProxyAddresses $ProxyAddresses

        if ($primary) {
            Write-Host "Primary SMTP address detected as: $primary" -ForegroundColor Cyan

            Set-MailUser -Identity $Identity -EmailAddressPolicyEnabled $false -ErrorAction Stop
            Set-MailUser -Identity $Identity -EmailAddresses $primary -ErrorAction Stop

            Write-Host "Updated mail user: $Identity" -ForegroundColor Green
        }
        else {
            $warning = "No primary SMTP address with uppercase SMTP: was found."
            Write-Host "WARNING: $warning Mail user: $Identity" -ForegroundColor Red
            Add-ErrorRecord -RecipientType "MailUser" -Identity $Identity -Reason "Primary SMTP not found" -Details $warning
        }
    }
    catch {
        Write-Host "ERROR: Failed to process mail user $Identity. $($_.Exception.Message)" -ForegroundColor Red
        Add-ErrorRecord -RecipientType "MailUser" -Identity $Identity -Reason "Processing failed" -Details $_.Exception.Message
    }
}

function Invoke-MailContactCleanup {
    param (
        [Parameter(Mandatory)]
        [string]$Identity,

        [string[]]$ProxyAddresses
    )

    try {
        Write-Host "Processing mail contact: $Identity" -ForegroundColor Yellow

        if (-not $ProxyAddresses -or $ProxyAddresses.Count -eq 0) {
            Write-Host "No proxy addresses provided from CSV. Reading mail contact from Exchange Online..." -ForegroundColor Cyan

            $mailContact = Get-MailContact -Identity $Identity -ErrorAction Stop
            $ProxyAddresses = $mailContact.EmailAddresses
        }

        $primary = Get-PrimarySmtpFromAddresses -ProxyAddresses $ProxyAddresses

        if ($primary) {
            Write-Host "Primary SMTP address detected as: $primary" -ForegroundColor Cyan

            Set-MailContact -Identity $Identity -EmailAddressPolicyEnabled $false -ErrorAction Stop
            Set-MailContact -Identity $Identity -EmailAddresses $primary -ErrorAction Stop

            Write-Host "Updated mail contact: $Identity" -ForegroundColor Green
        }
        else {
            $warning = "No primary SMTP address with uppercase SMTP: was found."
            Write-Host "WARNING: $warning Mail contact: $Identity" -ForegroundColor Red
            Add-ErrorRecord -RecipientType "MailContact" -Identity $Identity -Reason "Primary SMTP not found" -Details $warning
        }
    }
    catch {
        Write-Host "ERROR: Failed to process mail contact $Identity. $($_.Exception.Message)" -ForegroundColor Red
        Add-ErrorRecord -RecipientType "MailContact" -Identity $Identity -Reason "Processing failed" -Details $_.Exception.Message
    }
}

function Invoke-UsersAndContactsFileCleanup {
    Start-LogIfConfigured

    $script:InputPath = Select-FilePath `
        -Title "Select users and contacts input CSV file" `
        -Filter "CSV files (*.csv)|*.csv|All files (*.*)|*.*"

    if ([string]::IsNullOrWhiteSpace($script:InputPath)) {
        Write-Host "No input path was selected." -ForegroundColor Red
        return
    }

    if (-not (Test-Path -Path $script:InputPath)) {
        Write-Host "Input CSV file was not found at path: $script:InputPath" -ForegroundColor Red
        Add-ErrorRecord -RecipientType "N/A" -Identity "N/A" -Reason "Input file not found" -Details $script:InputPath
        return
    }

    try {
        Write-Host "Collecting mail users and mail contacts from: $script:InputPath" -ForegroundColor Cyan

        $recipients = Import-Csv -Path $script:InputPath

        foreach ($r in $recipients) {
            $identity = $r.Identity
            $recipientType = $r.RecipientType

            if ([string]::IsNullOrWhiteSpace($identity)) {
                Write-Host "WARNING: CSV row missing Identity value." -ForegroundColor Red
                Add-ErrorRecord -RecipientType "N/A" -Identity "N/A" -Reason "Missing Identity" -Details "A CSV row did not contain an Identity value."
                continue
            }

            if ([string]::IsNullOrWhiteSpace($recipientType)) {
                Write-Host "WARNING: CSV row missing RecipientType value for $identity." -ForegroundColor Red
                Add-ErrorRecord -RecipientType "N/A" -Identity $identity -Reason "Missing RecipientType" -Details "RecipientType must be MailUser or MailContact."
                continue
            }

            $proxyAddresses = $r."Proxy Addresses" -split '[;,`r`n]+' | ForEach-Object {
                $_.Trim()
            } | Where-Object {
                -not [string]::IsNullOrWhiteSpace($_)
            }

            switch ($recipientType) {
                "MailUser" {
                    Invoke-MailUserCleanup -Identity $identity -ProxyAddresses $proxyAddresses
                }

                "MailContact" {
                    Invoke-MailContactCleanup -Identity $identity -ProxyAddresses $proxyAddresses
                }

                default {
                    Write-Host "WARNING: Unsupported RecipientType '$recipientType' for $identity. Use MailUser or MailContact." -ForegroundColor Red
                    Add-ErrorRecord -RecipientType $recipientType -Identity $identity -Reason "Unsupported RecipientType" -Details "RecipientType must be MailUser or MailContact."
                }
            }
        }

        Write-Host "Completed processing users and contacts input file." -ForegroundColor Green
    }
    catch {
        Write-Host "ERROR: Failed to process input file. $($_.Exception.Message)" -ForegroundColor Red
        Add-ErrorRecord -RecipientType "N/A" -Identity "N/A" -Reason "Input file processing failed" -Details $_.Exception.Message
    }
}

function New-ExampleCsv {
    $ExamplePath = Select-SaveFilePath `
        -Title "Select example CSV output path" `
        -Filter "CSV files (*.csv)|*.csv|All files (*.*)|*.*" `
        -DefaultFileName "MailRecipientExample.csv"

    if ([string]::IsNullOrWhiteSpace($ExamplePath)) {
        Write-Host "No output path was selected." -ForegroundColor Red
        return
    }

    $ExampleDirectory = Split-Path -Path $ExamplePath -Parent

    if (-not [string]::IsNullOrWhiteSpace($ExampleDirectory) -and -not (Test-Path -Path $ExampleDirectory)) {
        New-Item -Path $ExampleDirectory -ItemType Directory -Force | Out-Null
    }

    @(
        [pscustomobject]@{
            Identity          = "mailuser1@contoso.com"
            "Proxy Addresses" = "SMTP:mailuser1@contoso.com;smtp:alias1@contoso.com;smtp:oldalias1@contoso.com"
            RecipientType     = "MailUser"
        },
        [pscustomobject]@{
            Identity          = "contact1@contoso.com"
            "Proxy Addresses" = "SMTP:contact1@contoso.com;smtp:alias2@contoso.com;smtp:oldalias2@contoso.com"
            RecipientType     = "MailContact"
        }
    ) | Export-Csv -Path $ExamplePath -NoTypeInformation -Encoding UTF8

    Write-Host "Example Excel-readable CSV created at: $ExamplePath" -ForegroundColor Green
}

function Show-MainMenu {
    Clear-Host

    Write-Host "Mail Recipient Primary SMTP Cleanup" -ForegroundColor Cyan
    Write-Host "===================================" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "0. Users and Contacts Fix"
    Write-Host "1. Generate example Excel-readable CSV"
    Write-Host "2. Generate output log"
    Write-Host "3. Generate errors list"
    Write-Host "Q. Quit"
    Write-Host ""
}

function Show-UsersAndContactsFixMenu {
    do {
        Clear-Host

        Write-Host "0. Users and Contacts Fix" -ForegroundColor Cyan
        Write-Host "=========================" -ForegroundColor Cyan
        Write-Host ""
        Write-Host "1. Run fix against a specific mail user"
        Write-Host "2. Run fix against a specific mail contact"
        Write-Host "3. Run fix from CSV using RecipientType column"
        Write-Host "R. Return to main menu"
        Write-Host ""

        $selection = Read-Host "Select an option"

        switch ($selection.ToUpper()) {
            "1" {
                Start-LogIfConfigured

                $Identity = Read-Host "Enter the mail user identity, alias, SMTP address, or distinguished name"

                if ([string]::IsNullOrWhiteSpace($Identity)) {
                    Write-Host "No identity was entered." -ForegroundColor Red
                }
                else {
                    Invoke-MailUserCleanup -Identity $Identity
                }

                Read-Host "Press Enter to continue"
            }

            "2" {
                Start-LogIfConfigured

                $Identity = Read-Host "Enter the mail contact identity, alias, SMTP address, or distinguished name"

                if ([string]::IsNullOrWhiteSpace($Identity)) {
                    Write-Host "No identity was entered." -ForegroundColor Red
                }
                else {
                    Invoke-MailContactCleanup -Identity $Identity
                }

                Read-Host "Press Enter to continue"
            }

            "3" {
                Invoke-UsersAndContactsFileCleanup
                Read-Host "Press Enter to continue"
            }

            "R" {
                return
            }

            default {
                Write-Host "Invalid selection. Select 1, 2, 3, or R." -ForegroundColor Red
                Read-Host "Press Enter to continue"
            }
        }
    }
    while ($true)
}

