function Show-OutputLogMenu {
    do {
        Clear-Host

        Write-Host "2. Generate Output Log" -ForegroundColor Cyan
        Write-Host "======================" -ForegroundColor Cyan
        Write-Host ""
        Write-Host "1. Select transcript log output path"
        Write-Host "2. Start transcript logging"
        Write-Host "R. Return to main menu"
        Write-Host ""

        $selection = Read-Host "Select an option"

        switch ($selection.ToUpper()) {
            "1" {
                $script:TranscriptPath = Select-SaveFilePath `
                    -Title "Select transcript log output path" `
                    -Filter "Log files (*.log)|*.log|Text files (*.txt)|*.txt|All files (*.*)|*.*" `
                    -DefaultFileName "MailRecipientCleanup.log"

                if ([string]::IsNullOrWhiteSpace($script:TranscriptPath)) {
                    Write-Host "No transcript path was selected." -ForegroundColor Red
                }
                else {
                    Write-Host "Transcript log path set to: $script:TranscriptPath" -ForegroundColor Green
                }

                Read-Host "Press Enter to continue"
            }

            "2" {
                Start-LogIfConfigured

                if ($script:TranscriptStarted) {
                    Write-Host "Transcript logging is active." -ForegroundColor Green
                }
                else {
                    Write-Host "Transcript logging was not started. Confirm a transcript path is configured." -ForegroundColor Red
                }

                Read-Host "Press Enter to continue"
            }

            "R" {
                return
            }

            default {
                Write-Host "Invalid selection. Select 1, 2, or R." -ForegroundColor Red
                Read-Host "Press Enter to continue"
            }
        }
    }
    while ($true)
}

function Show-ErrorListMenu {
    do {
        Clear-Host

        Write-Host "3. Generate Errors List" -ForegroundColor Cyan
        Write-Host "=======================" -ForegroundColor Cyan
        Write-Host ""
        Write-Host "1. Select error list CSV output path"
        Write-Host "2. Export current error list"
        Write-Host "R. Return to main menu"
        Write-Host ""

        $selection = Read-Host "Select an option"

        switch ($selection.ToUpper()) {
            "1" {
                $script:ErrorListPath = Select-SaveFilePath `
                    -Title "Select error list CSV output path" `
                    -Filter "CSV files (*.csv)|*.csv|All files (*.*)|*.*" `
                    -DefaultFileName "MailRecipientErrors.csv"

                if ([string]::IsNullOrWhiteSpace($script:ErrorListPath)) {
                    Write-Host "No error list path was selected." -ForegroundColor Red
